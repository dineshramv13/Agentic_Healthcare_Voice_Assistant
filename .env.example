

# --- LLM Provider (OpenRouter — free tier, no card required) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Free model used for all LLM calls (generation, intent classification, verification, judging)
# Other free options: "meta-llama/llama-3.1-8b-instruct:free", "google/gemma-2-9b-it:free"
MODEL_NAME="openrouter/owl-alpha"

# Backup/fallback model if the primary free model is rate-limited
FALLBACK_MODEL_NAME="google/gemma-4-31b-it:free"

# --- RAG / Vector Store ---
# Local persistent ChromaDB folder (no cloud, no API key needed)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=docs

# Embedding model (local, free, runs on CPU via sentence-transformers)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval
RETRIEVAL_TOP_K=5
RERANK_TOP_N=3

# --- Source documents folder for ingestion ---
DOCS_DIR=./docs

# --- General ---
LOG_LEVEL=INFO
SESSION_DB_PATH=./sessions.db
TRACE_DIR=./traces

# --- LLM behavior ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
